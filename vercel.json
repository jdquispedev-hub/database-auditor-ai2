{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/analyze_python.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/analyze_python",
      "dest": "api/analyze_python.py"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
